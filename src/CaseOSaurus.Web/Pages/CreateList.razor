@using CaseOSaurus.Application.Queries.GetCases
@using CaseOSaurus.Domain.Enums
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components

@page "/cases"
@attribute [Authorize]

@inject HttpClient Http

<h3>Cases</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (cases == null || !cases.Any())
{
    <p>No cases found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Status</th>
                <th>Assigned To</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in cases)
            {
                <tr>
                    <td>@c.Id.ToString()[..8]</td>
                    <td>@c.Title</td>
                    <td>
                        <select value="@c.Status" @onchange="(e) => OnStatusChanged(c, e.Value?.ToString() ?? c.Status)" class="form-select form-select-sm">
                            @foreach (var status in GetAvailableStatuses())
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </td>
                    <td>@(string.IsNullOrEmpty(c.AssignedTo) ? "Unassigned" : c.AssignedTo)</td>
                    <td>@c.CreatedAt.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => AssignCase(c.Id)">Assign</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showAssignModal)
{
    <div class="modal show" style="display:block">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Assign Case</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="assigneeInput" class="form-label">User ID</label>
                        <input id="assigneeInput" class="form-control" @bind="assigneeUserId" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SubmitAssign">Assign</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private List<CaseSummary>? cases;
    private bool isLoading = true;
    private string? errorMessage;
    private bool showAssignModal = false;
    private string assigneeUserId = string.Empty;
    private Guid selectedCaseId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCases();
    }

    private async Task LoadCases()
    {
        try
        {
            isLoading = true;
            cases = await Http.GetFromJsonAsync<List<CaseSummary>>("/api/cases");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load cases: {ex.Message}";
            cases = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<string> GetAvailableStatuses()
    {
        return Enum.GetValues<CaseStatus>().Select(s => s.ToString()).ToList();
    }

    private async Task UpdateStatus(CaseSummary caseSummary)
    {
        try
        {
            var response = await Http.PatchAsJsonAsync(
                $"/api/cases/{caseSummary.Id}/status",
                new { status = caseSummary.Status }
            );
            if (!response.IsSuccessStatusCode)
            {
                await LoadCases(); // reload to revert UI
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to update status: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            await LoadCases();
        }
    }

    private void AssignCase(Guid id)
    {
        selectedCaseId = id;
        showAssignModal = true;
    }

    private void CloseModal()
    {
        showAssignModal = false;
        assigneeUserId = string.Empty;
    }

    private async Task SubmitAssign()
    {
        if (string.IsNullOrWhiteSpace(assigneeUserId))
            return;

        try
        {
            var response = await Http.PatchAsJsonAsync($"/api/cases/{selectedCaseId}/assign", new { assignedTo = assigneeUserId });
            if (response.IsSuccessStatusCode)
            {
                await LoadCases();
                CloseModal();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to assign: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private async Task OnStatusChanged(CaseSummary caseSummary, string newStatus)
    {
        caseSummary.Status = newStatus;
        await UpdateStatus(caseSummary);
    }
}
