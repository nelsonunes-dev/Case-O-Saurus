@using CaseOSaurus.Web.Models
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization

@page "/create-case"
@attribute [Authorize]

@inject HttpClient Http

<h3>Create New Case</h3>

<EditForm Model="@newCase" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <InputText id="title" class="form-control" @bind-Value="newCase.Title" />
        <ValidationMessage For="@(() => newCase.Title)" />
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <InputTextArea id="description" class="form-control" @bind-Value="newCase.Description" />
    </div>

    <div class="mb-3">
        <label for="priority" class="form-label">Priority</label>
        <InputSelect id="priority" class="form-select" @bind-Value="newCase.Priority">
            <option value="">Select</option>
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
        </InputSelect>
        <ValidationMessage For="@(() => newCase.Priority)" />
    </div>

    <div class="mb-3">
        <label for="type" class="form-label">Case Type</label>
        <InputSelect id="type" class="form-select" @bind-Value="newCase.Type">
            <option value="">Select</option>
            <option value="ServiceRequest">Service Request</option>
            <option value="Incident">Incident</option>
            <option value="Complaint">Complaint</option>
        </InputSelect>
        <ValidationMessage For="@(() => newCase.Type)" />
    </div>

    <div class="mb-3">
        <label for="requestor" class="form-label">Requestor (Email)</label>
        <InputText id="requestor" class="form-control" @bind-Value="newCase.Requestor" />
        <ValidationMessage For="@(() => newCase.Requestor)" />
    </div>

    <div class="mb-3">
        <label for="assignedTo" class="form-label">Assign To (User ID)</label>
        <InputText id="assignedTo" class="form-control" @bind-Value="newCase.AssignedTo" />
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
</EditForm>

@if (submitted)
{
    <div class="alert alert-success mt-3">Case created successfully! ID: @createdCaseId</div>
}

@code {
    private CreateCaseModel newCase = new();
    private bool submitted = false;
    private Guid? createdCaseId = null;

    private async Task HandleValidSubmit()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/cases", newCase);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<dynamic>();
                createdCaseId = result?.Id;
                submitted = true;
                newCase = new(); // reset form
            }
            else
            {
                // Show error
            }
        }
        catch (Exception ex)
        {
            // Handle
        }
    }
}
